{
  "name": "atlas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Atlas — open-source, local-first personal travel-map editor with an optional self-hostable sharing backend",
  "license": "MIT",
  "author": "hlibsuslov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hlibsuslov/atlas-travel-editor.git"
  },
  "homepage": "https://github.com/hlibsuslov/atlas-travel-editor#readme",
  "bugs": {
    "url": "https://github.com/hlibsuslov/atlas-travel-editor/issues"
  },
  "keywords": [
    "local-first",
    "travel",
    "map",
    "cartography",
    "pwa",
    "offline",
    "indexeddb",
    "self-hosted",
    "react",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:docs": "node scripts/check-no-supabase-docs.mjs",
    "check:locales": "node scripts/check-locales.mjs",
    "ci": "npm run typecheck && npm run lint && npm run check:docs && npm run check:locales && npm run test && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.56.0",
    "@tanstack/react-query": "^5.59.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "immer": "^10.1.1",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.26.2",
    "react-simple-maps": "^3.0.0",
    "sonner": "^2.0.7",
    "world-atlas": "^2.0.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
