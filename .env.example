# Atlas is LOCAL-FIRST: it needs NO configuration to run.
# Just `npm install && npm run dev` — the app boots straight into the editor and
# stores everything locally in your browser (IndexedDB), fully offline, no account.
#
# Every variable below is OPTIONAL.

# --- App config ---
# Public base URL, used to build share links. Defaults to the current origin.
VITE_APP_URL=http://localhost:5173

# --- Self-hostable sharing/social backend (optional, shipped) ---
# Point the app at an Atlas Server instance to enable profiles, public maps, and
# follows. Leave unset for pure local-first mode (sharing/social UI stays hidden).
# VITE_SELFHOST_URL=https://atlas.example.com

# Force pure local-first mode even if a backend URL is set (no login wall).
# VITE_LOCAL_ONLY=1

# --- Observability (optional) ---
# If set, enables Sentry error/performance monitoring in the browser.
VITE_SENTRY_DSN=

# --- Local demo auth (development only) ---
# When VITE_DEMO_AUTH=1, an explorable demo login screen accepts the credentials
# below. Not needed for normal local-first use. Leave unset/0 in production.
VITE_DEMO_AUTH=0
VITE_DEMO_LOGIN=1
VITE_DEMO_PASSWORD=1
