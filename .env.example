# --- Supabase (client-safe) ---
# These are exposed to the browser by design. Security is enforced by
# Row Level Security (RLS) in Postgres, NOT by hiding these values.
# The anon key is a public, RLS-scoped key — never put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- App config ---
# Public base URL, used to build share links.
VITE_APP_URL=http://localhost:5173

# --- Observability (optional) ---
# If set, enables Sentry error/performance monitoring in the browser.
VITE_SENTRY_DSN=

# --- Local demo auth (development only) ---
# When VITE_DEMO_AUTH=1, the login screen accepts the demo credentials below
# and runs entirely against localStorage (no Supabase needed). Leave unset/0
# in production.
VITE_DEMO_AUTH=0
VITE_DEMO_LOGIN=1
VITE_DEMO_PASSWORD=1
